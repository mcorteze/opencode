# ============================================================
# CONFIGURACION DE API KEYS — OpenCode Setup
# ============================================================
# Copia este archivo como .env y rellena tus keys reales.
# NUNCA compartas el .env ni lo subas a git (ya esta en .gitignore).
#
# Deja en blanco (=) los proveedores que no uses.
# El menu ignora automaticamente los campos vacios.
#
# Formato: PROVEEDOR_KEY_NOMBREPERFILSINESPACIO
# Ejemplo: perfil "Gmail 1" -> sufijo GMAIL1
#          perfil "Gmail 2" -> sufijo GMAIL2
# ============================================================

# --- Perfil: Gmail 1 ---
GROQ_KEY_GMAIL1=
OPENROUTER_KEY_GMAIL1=
ANTHROPIC_KEY_GMAIL1=
OPENAI_KEY_GMAIL1=
GEMINI_KEY_GMAIL1=

# --- Perfil: Gmail 2 ---
GROQ_KEY_GMAIL2=
OPENROUTER_KEY_GMAIL2=
ANTHROPIC_KEY_GMAIL2=
OPENAI_KEY_GMAIL2=
GEMINI_KEY_GMAIL2=

# --- Perfil: Gmail 3 ---
GROQ_KEY_GMAIL3=
OPENROUTER_KEY_GMAIL3=
ANTHROPIC_KEY_GMAIL3=
OPENAI_KEY_GMAIL3=
GEMINI_KEY_GMAIL3=
